{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "MonitoredDomain": {
      "title": "Tracked Domain",
      "description": "A website domain being monitored for GEO/SEO.",
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["domain", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user records."
    },
    "/domains/{domainId}": {
      "schema": "MonitoredDomain",
      "description": "Domains being tracked by users."
    }
  }
}
