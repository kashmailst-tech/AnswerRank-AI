rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email.lower() == 'kashmail.st@gmail.com';
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['uid', 'email']) &&
                      incoming().uid == request.auth.uid;
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid;
    }

    // Monitored Domains
    match /domains/{domainId} {
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      isValidId(domainId);
      allow delete: if (isSignedIn() && existing().userId == request.auth.uid) || isAdmin();
    }
  }
}
